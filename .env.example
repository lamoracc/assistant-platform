APP_ENV=development

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=assistant
POSTGRES_USER=assistant
POSTGRES_PASSWORD=assistant
DATABASE_URL=postgresql+psycopg://assistant:assistant@postgres:5432/assistant

REDIS_URL=redis://redis:6379/0

QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_NAME=document_chunks

EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_DIMENSIONS=1024
EMBEDDING_BATCH_SIZE=32
INGESTION_EMBED_BATCH_CHUNKS=256
HF_HOME=/root/.cache/huggingface
TRANSFORMERS_CACHE=/root/.cache/huggingface/transformers
SENTENCE_TRANSFORMERS_HOME=/root/.cache/huggingface/sentence-transformers

UPLOAD_MAX_BYTES=26214400

RETRIEVAL_TOP_K=8
RETRIEVAL_CANDIDATE_K=80
RETRIEVAL_FINAL_K=8
RETRIEVAL_KEYWORD_CANDIDATE_K=80
RETRIEVAL_MIN_SCORE=0.55
RETRIEVAL_NEAR_DUPLICATE_DEDUPE=true
RETRIEVAL_NEAR_DUPLICATE_THRESHOLD=0.92
RETRIEVAL_MAX_NEAR_DUPLICATES_PER_GROUP=1
MAX_CONTEXT_CHARS=12000
LLM_PROVIDER_URL=
LLM_MODEL_NAME=qwen
RERANKER_MODEL_NAME=
RERANKER_BATCH_SIZE=16
ASSISTANT_SYSTEM_PROMPT=
PRESERVE_SOURCE_TERMS_INSTRUCTION=
# LLM_PROVIDER_URL=http://192.168.20.108:1234
# LLM_MODEL_NAME=qwen3.5-27b
